# Copy this file to .env and fill in real values.
# Spring Boot reads these via application-local.properties placeholders.

# ── Mail (Google SMTP) ───────────────────────────────────────────────────────
# Leave all MAIL_* unset (or keep defaults) to use the local dummy mailer.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your-app-password   # Gmail → Security → App passwords
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# ── JWT ──────────────────────────────────────────────────────────────────────
# JWT_SECRET=          # base64-encoded, min 32 bytes (openssl rand -base64 32)

# ── Superuser ────────────────────────────────────────────────────────────────
# SUPERUSER_EMAIL=owner@garden.local
# SUPERUSER_PASSWORD=changeme

# ── Google OAuth2 ────────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Stripe ───────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
